{
  "manifest_version": 3,
  "name": "Nebula for Claude",
  "version": "1.1.0",
  "description": "Ambient deep-space atmosphere for claude.ai — animated backgrounds, glassmorphism panels, and focus tools.",
  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_title": "Nebula for Claude",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}
